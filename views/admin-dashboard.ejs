<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="../css/admin.css">
</head>

<body>
    <header>
        <h1>Admin Dashboard</h1>
        <div style="display: flex; gap: 1rem;">
            <button class="btn btn-primary" onclick="showNewFolderModal()">
                <span>+</span> Neuer Ordner
            </button>
            <a href="/" class="btn">Galerie</a>
            <a href="/admin/logout" class="btn btn-danger">Abmelden</a>
        </div>
    </header>

    <main>
        <% if (Object.keys(structuredData).length===0) { %>
            <div class="empty-state">
                <h2>Noch keine Ordner vorhanden</h2>
                <p>Erstelle deinen ersten Ordner mit dem Button oben rechts</p>
            </div>
            <% } %>

                <% Object.keys(structuredData).sort((a,b)=> b-a).forEach(year => { %>
                    <section class="year-section">
                        <h2 class="year-header">
                            <%= year %>
                        </h2>

                        <% Object.keys(structuredData[year]).forEach(month=> { %>
                            <div class="month-section">
                                <h3 class="month-title">
                                    <%= month %>
                                </h3>

                                <div class="folder-grid">
                                    <% structuredData[year][month].forEach(folder=> { %>
                                        <div class="folder-card <%= folder.images.length === 0 ? 'empty-folder' : '' %>"
                                            data-year="<%= folder.year %>" data-month="<%= folder.month %>"
                                            data-category="<%= folder.category %>"
                                            onclick="openFolder('<%= folder.year %>', '<%= folder.month %>', '<%= folder.category %>')"
                                            ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)"
                                            ondrop="handleDrop(event, '<%= folder.year %>', '<%= folder.month %>', '<%= folder.category %>')">

                                            <div class="drop-overlay">
                                                <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">📥</div>
                                                <div>Bilder hier ablegen</div>
                                            </div>

                                            <div class="folder-cover">
                                                <% if (folder.cover) { %>
                                                    <img src="/bilder/<%= folder.path %>/<%= folder.cover %>" alt="">
                                                    <% } else { %>
                                                        <div class="empty-cover">
                                                            <span>📂</span>
                                                            <div>Leer</div>
                                                        </div>
                                                        <% } %>
                                                            <div class="folder-cover-overlay">
                                                                <span
                                                                    class="folder-image-count <%= folder.isEmpty ? 'empty-badge' : '' %>">
                                                                    <%= folder.images.length %> Bilder
                                                                </span>
                                                            </div>
                                            </div>

                                            <div class="folder-info">
                                                <span class="folder-name">
                                                    <%= folder.category %>
                                                </span>
                                                <button class="folder-delete"
                                                    onclick="event.stopPropagation(); deleteFolder('<%= folder.year %>', '<%= folder.month %>', '<%= folder.category %>')"
                                                    title="Löschen">
                                                    🗑️
                                                </button>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                            <% }) %>
                    </section>
                    <% }) %>
    </main>

    <!-- Folder Detail Modal -->
    <div class="folder-modal" id="folderModal">
        <div class="folder-modal-header">
            <div class="folder-modal-title">
                <h2 id="modalFolderName">Ordner</h2>
                <p id="modalFolderPath">Pfad</p>
            </div>
            <div class="folder-modal-actions">
                <button class="btn btn-primary" onclick="document.getElementById('modalFileInput').click()">
                    📷 Bilder hinzufügen
                </button>
                <input type="file" id="modalFileInput" multiple accept="image/*" style="display:none"
                    onchange="uploadToCurrentFolder(this.files)">
                <button class="btn" onclick="closeFolderModal()" style="font-size: 1.5rem;">×</button>
            </div>
        </div>

        <div class="drop-zone" id="modalDropZone" ondragover="handleModalDragOver(event)"
            ondragleave="handleModalDragLeave(event)" ondrop="handleModalDrop(event)">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📁</div>
            <div class="drop-zone-text">Bilder hierher ziehen oder klicken zum Durchsuchen</div>
        </div>

        <div class="modal-image-grid" id="modalImageGrid">
            <!-- Wird dynamisch gefüllt -->
        </div>
    </div>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
        <button class="lightbox-close" onclick="closeLightbox()">×</button>
        <button class="lightbox-nav lightbox-prev" onclick="navigateLightbox(-1)">‹</button>
        <img id="lightboxImg" src="" alt="">
        <button class="lightbox-nav lightbox-next" onclick="navigateLightbox(1)">›</button>
    </div>

    <!-- New Folder Modal -->
    <div class="modal-overlay" id="newFolderModal" onclick="if(event.target === this) hideNewFolderModal()">
        <div class="modal-content">
            <div class="modal-header">
                <h2>📁 Neuer Ordner</h2>
                <button class="btn" onclick="hideNewFolderModal()" style="padding: 0.5rem;">×</button>
            </div>
            <div class="modal-body">
                <form id="newFolderForm" onsubmit="createNewFolder(event)">
                    <div class="form-group">
                        <label>Jahr</label>
                        <input type="number" name="year" value="<%= new Date().getFullYear() %>" required>
                    </div>
                    <div class="form-group">
                        <label>Monat</label>
                        <select name="month" required>
                            <% const
                                monate=["Januar","Februar","März","April","Mai","Juni","Juli","August","September","Oktober","November","Dezember"];
                                %>
                                <% monate.forEach((m, i)=> { %>
                                    <option value="<%= m %>" <%=i===new Date().getMonth() ? 'selected' : '' %>><%= m %>
                                    </option>
                                    <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Ordnername</label>
                        <input type="text" name="category" placeholder="z.B. Urlaub, Events..." required>
                    </div>
                    <div class="form-group">
                        <label>Bilder (optional)</label>
                        <div class="file-input-wrapper" onclick="document.getElementById('newFolderFiles').click()">
                            <div style="font-size: 2rem; margin-bottom: 0.5rem;">📷</div>
                            <div>Klicken zum Auswählen oder hereinziehen</div>
                            <div id="fileList"></div>
                        </div>
                        <input type="file" id="newFolderFiles" multiple accept="image/*" style="display:none"
                            onchange="updateFileList(this)">
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem;">
                        Ordner erstellen
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Upload Progress -->
    <div class="upload-progress" id="uploadProgress">
        <div id="uploadText">Upload...</div>
        <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
        </div>
    </div>

    <script>
        let currentFolder = null;
        let currentImages = [];
        let currentImageIndex = 0;

        async function uploadToCurrentFolder(files) {
            if (!currentFolder) {
                showToast('Kein Ordner ausgewählt', 'error');
                return;
            }

            if (!files || files.length === 0) return;

            const fileArray = Array.from(files);

            await uploadFiles(fileArray, currentFolder.year, currentFolder.month, currentFolder.category);

            setTimeout(() => {
                openFolder(currentFolder.year, currentFolder.month, currentFolder.category);
            }, 500);
        }

        function handleDragOver(e) {
            e.preventDefault();
            const card = e.currentTarget;
            if (e.dataTransfer.types.includes('Files')) {
                card.classList.add('drag-over');
            }
        }

        function handleDragLeave(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        async function handleDrop(e, year, month, category) {
            e.preventDefault();
            e.stopPropagation();
            e.currentTarget.classList.remove('drag-over');

            const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
            if (files.length === 0) {
                return;
            }

            await uploadFiles(files, year, month, category);
            setTimeout(() => location.reload(), 500);
        }

        async function openFolder(year, month, category) {
            currentFolder = { year, month, category };

            const res = await fetch(`/admin/api/folder?year=${ year }&month=${ month }&category=${ category }`);
            const data = await res.json();

            if (!data.success) {
                showToast('Fehler beim Laden', 'error');
                return;
            }

            currentImages = data.images;

            document.getElementById('modalFolderName').textContent = category;
            document.getElementById('modalFolderPath').textContent = `${ month } ${ year } • ${ data.images.length } Bilder`;

            renderModalImages(data.images, data.path);
            document.getElementById('folderModal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function renderModalImages(images, path) {
            const grid = document.getElementById('modalImageGrid');

            if (images.length === 0) {
                grid.innerHTML = '<div class="empty-state" style="grid-column: 1/-1;"><h3>Keine Bilder</h3><p>Ziehe Bilder hierher oder klicke "Bilder hinzufügen"</p></div>';
                return;
            }

            grid.innerHTML = images.map((img, idx) => `
                <div class="modal-image-item" onclick="openLightbox(${ idx })">
                    <img src="/bilder/${ path }/${ img }" alt="" loading="lazy">
                    <button class="image-delete-btn" onclick="event.stopPropagation(); deleteImage('${ img }')">×</button>
                </div>
            `).join('');
        }

        function closeFolderModal() {
            document.getElementById('folderModal').classList.remove('active');
            document.body.style.overflow = '';
            currentFolder = null;
        }

        function handleModalDragOver(e) {
            e.preventDefault();
            document.getElementById('modalDropZone').classList.add('drag-over');
        }

        function handleModalDragLeave(e) {
            document.getElementById('modalDropZone').classList.remove('drag-over');
        }

        async function handleModalDrop(e) {
            e.preventDefault();
            e.stopPropagation();
            document.getElementById('modalDropZone').classList.remove('drag-over');

            const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
            if (files.length === 0) {
                showToast('⚠️ Nur Bilder vom Desktop erlaubt', 'warning');
                return;
            }

            await uploadFiles(files, currentFolder.year, currentFolder.month, currentFolder.category);
            setTimeout(() => {
                if (currentFolder) {
                    openFolder(currentFolder.year, currentFolder.month, currentFolder.category);
                }
            }, 500);
        }

        async function uploadFiles(files, year, month, category) {
            const progress = document.getElementById('uploadProgress');
            const progressFill = document.getElementById('progressFill');
            const uploadText = document.getElementById('uploadText');

            progress.classList.add('active');
            uploadText.textContent = `Uploading ${ files.length } Bilder...`;
            progressFill.style.width = '0%';

            const formData = new FormData();
            files.forEach(f => formData.append('images', f));
            formData.append('year', year);
            formData.append('month', month);
            formData.append('category', category);

            return new Promise((resolve, reject) => {
                const xhr = new XMLHttpRequest();

                xhr.upload.onprogress = (e) => {
                    if (e.lengthComputable) {
                        progressFill.style.width = (e.loaded / e.total * 100) + '%';
                    }
                };

                xhr.onload = () => {
                    try {
                        const res = JSON.parse(xhr.responseText);
                        if (res.success) {
                            uploadText.textContent = `✅ ${ res.count } Bilder hochgeladen`;
                            setTimeout(() => progress.classList.remove('active'), 1500);
                            resolve(res);
                        } else {
                            throw new Error(res.error);
                        }
                    } catch (err) {
                        uploadText.textContent = '❌ Fehler';
                        setTimeout(() => progress.classList.remove('active'), 3000);
                        reject(err);
                    }
                };

                xhr.onerror = () => {
                    uploadText.textContent = '❌ Netzwerkfehler';
                    setTimeout(() => progress.classList.remove('active'), 3000);
                    reject(new Error('Network error'));
                };

                xhr.open('POST', '/admin/upload');
                xhr.send(formData);
            });
        }

        function openLightbox(index) {
            currentImageIndex = index;
            updateLightbox();
            document.getElementById('lightbox').classList.add('active');
        }

        function updateLightbox() {
            const img = currentImages[currentImageIndex];
            const path = `${ currentFolder.year }/${ getMonthFolderName(currentFolder.month) }/${ currentFolder.category }`;
            document.getElementById('lightboxImg').src = `/bilder/${ path }/${ img }`;
        }

        function navigateLightbox(dir) {
            currentImageIndex += dir;
            if (currentImageIndex < 0) currentImageIndex = currentImages.length - 1;
            if (currentImageIndex >= currentImages.length) currentImageIndex = 0;
            updateLightbox();
        }

        function closeLightbox(e) {
            if (e && e.target !== e.currentTarget && !e.target.classList.contains('lightbox-close')) return;
            document.getElementById('lightbox').classList.remove('active');
        }

        async function deleteImage(filename) {
            if (!confirm('Bild wirklich löschen?')) return;

            const res = await fetch('/admin/delete-image', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ...currentFolder, filename })
            });

            const data = await res.json();
            if (data.success) {
                openFolder(currentFolder.year, currentFolder.month, currentFolder.category);
            }
        }

        async function deleteFolder(year, month, category) {
            if (!confirm(`Ordner "${ category }" wirklich löschen?\nAlle Bilder werden unwiderruflich gelöscht!`)) return;

            const res = await fetch('/admin/delete-folder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ year, month, category })
            });

            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                showToast('Fehler beim Löschen', 'error');
            }
        }

        function showNewFolderModal() {
            document.getElementById('newFolderModal').classList.add('active');

            document.getElementById('newFolderForm').reset();
            document.getElementById('fileList').textContent = '';
            document.querySelector('.file-input-wrapper').classList.remove('has-files');
        }

        function hideNewFolderModal() {
            document.getElementById('newFolderModal').classList.remove('active');
        }

        function updateFileList(input) {
            const list = document.getElementById('fileList');
            const wrapper = document.querySelector('.file-input-wrapper');

            if (input.files.length > 0) {
                list.textContent = `${ input.files.length } Dateien ausgewählt`;
                wrapper.classList.add('has-files');
            } else {
                list.textContent = '';
                wrapper.classList.remove('has-files');
            }
        }

        async function createNewFolder(e) {
            e.preventDefault();

            const form = document.getElementById('newFolderForm');
            const formData = new FormData(form);
            const year = formData.get('year');
            const month = formData.get('month');
            const category = formData.get('category');
            const fileInput = document.getElementById('newFolderFiles');
            const files = fileInput.files;

            if (!year || !month || !category) {
                showToast('Bitte alle Felder ausfüllen', 'warning');
                return;
            }

            const progress = document.getElementById('uploadProgress');
            const progressFill = document.getElementById('progressFill');
            const uploadText = document.getElementById('uploadText');

            progress.classList.add('active');
            progressFill.style.width = '0%';

            try {
                uploadText.textContent = 'Erstelle Ordner...';

                const createRes = await fetch('/admin/create-folder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ year, month, category })
                });

                const createData = await createRes.json();

                if (!createData.success) {
                    throw new Error(createData.error || 'Ordner konnte nicht erstellt werden');
                }

                if (files.length > 0) {
                    uploadText.textContent = `Lade ${ files.length } Bilder hoch...`;

                    const uploadFormData = new FormData();
                    Array.from(files).forEach(f => uploadFormData.append('images', f));
                    uploadFormData.append('year', year);
                    uploadFormData.append('month', month);
                    uploadFormData.append('category', category);

                    await new Promise((resolve, reject) => {
                        const xhr = new XMLHttpRequest();

                        xhr.upload.onprogress = (e) => {
                            if (e.lengthComputable) {
                                progressFill.style.width = (e.loaded / e.total * 100) + '%';
                            }
                        };

                        xhr.onload = () => {
                            try {
                                const res = JSON.parse(xhr.responseText);
                                if (res.success) {
                                    uploadText.textContent = '✅ Fertig!';
                                    resolve(res);
                                } else {
                                    reject(new Error(res.error));
                                }
                            } catch (err) {
                                reject(err);
                            }
                        };

                        xhr.onerror = () => reject(new Error('Upload fehlgeschlagen'));
                        xhr.open('POST', '/admin/upload');
                        xhr.send(uploadFormData);
                    });
                } else {
                    uploadText.textContent = '✅ Ordner erstellt!';
                    progressFill.style.width = '100%';
                }

                setTimeout(() => {
                    hideNewFolderModal();
                    progress.classList.remove('active');
                    location.reload();
                }, 1000);

            } catch (err) {
                console.error('Error:', err);
                uploadText.textContent = '❌ Fehler: ' + err.message;
                setTimeout(() => progress.classList.remove('active'), 3000);
            }
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            const colors = {
                info: '#3b82f6',
                success: '#22c55e',
                warning: '#f59e0b',
                error: '#ef4444'
            };

            toast.style.cssText = `
                position: fixed;
                bottom: 2rem;
                left: 50%;
                transform: translateX(-50%);
                background: ${ colors[type] || colors.info };
                color: #fff;
                padding: 1rem 2rem;
                border-radius: 12px;
                z-index: 10000;
                font-weight: 600;
                box-shadow: 0 10px 30px rgba(0,0,0,0.3);
                animation: slideUp 0.3s ease;
            `;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function getMonthFolderName(monthName) {
            const monate = ["Januar", "Februar", "März", "April", "Mai", "Juni", "Juli", "August", "September", "Oktober", "November", "Dezember"];
            const index = monate.indexOf(monthName);
            const num = (index + 1).toString().padStart(2, "0");
            return `${ num }_${ monthName }`;
        }

        document.addEventListener('keydown', (e) => {
            if (document.getElementById('lightbox').classList.contains('active')) {
                if (e.key === 'ArrowLeft') navigateLightbox(-1);
                if (e.key === 'ArrowRight') navigateLightbox(1);
                if (e.key === 'Escape') closeLightbox();
            }
            if (e.key === 'Escape' && document.getElementById('folderModal').classList.contains('active')) {
                closeFolderModal();
            }
            if (e.key === 'Escape' && document.getElementById('newFolderModal').classList.contains('active')) {
                hideNewFolderModal();
            }
        });

        document.getElementById('modalDropZone').addEventListener('click', (e) => {
            if (e.target === e.currentTarget || e.target.closest('.drop-zone-text')) {
                document.getElementById('modalFileInput').click();
            }
        });
    </script>
</body>

</html>